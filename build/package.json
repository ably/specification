{
  "name": "@ably/specification-build",
  "version": "1.0.0",
  "scripts": {
    "clean": "rm -rf ./content ./public",
    "build": "npm-run-all clean build:prepare build:hugo build:anchors build:tailwind",
    "build:prepare": "./scripts/prepare-content",
    "build:hugo": "hugo",
    "build:anchors": "./scripts/add-spec-anchors",
    "build:tailwind": "tailwindcss -i ./layouts/main.css -o ./public/tailwind.css --minify",
    "lint": "npm-run-all format:*:check",
    "format:textile:check": "./scripts/find-duplicate-spec-items"
  },
  "repository": "ably/specification",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ably/specification/issues"
  },
  "homepage": "https://github.com/ably/specification",
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.1.8"
  }
}
